 <dlg:bulletinboard>
  <dlg:button dlg:style-id="0" dlg:id="cbAccept" dlg:tab-index="0" dlg:left="146" dlg:top="43" dlg:width="32" dlg:height="14" dlg:tabstop="true" dlg:value="Accept" dlg:valign="center" dlg:image-position="top-center"/>
  <dlg:button dlg:style-id="0" dlg:id="CommandButton1" dlg:tab-index="1" dlg:left="146" dlg:top="59" dlg:width="32" dlg:height="14" dlg:tabstop="true" dlg:value="Cancel" dlg:valign="center" dlg:image-position="top-center"/>
  <dlg:text dlg:style-id="1" dlg:id="Label1" dlg:tab-index="2" dlg:left="11" dlg:top="4" dlg:width="164" dlg:height="28" dlg:value="To apply the two-fraction equation of Wilcock (2001), you must supply gravel and sand fractions in channel bed as well as an estimate of surface grain size D65.  Click &quot;Accept&quot; to continue upon finishing the required input." dlg:valign="top" dlg:multiline="true" dlg:tabstop="false"/>
  <dlg:text dlg:style-id="1" dlg:id="Label2" dlg:tab-index="3" dlg:left="7" dlg:top="44" dlg:width="107" dlg:height="7" dlg:value="Estimate of surface grain size D65 (mm)" dlg:align="right" dlg:valign="top" dlg:multiline="true" dlg:tabstop="false"/>
