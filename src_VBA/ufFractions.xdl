  <dlg:text dlg:style-id="1" dlg:id="Label4" dlg:tab-index="5" dlg:left="7" dlg:top="65" dlg:width="107" dlg:height="7" dlg:value="Fraction of sand in channel bed" dlg:align="right" dlg:valign="top" dlg:multiline="true" dlg:tabstop="false"/>
